# ─── AdForge Environment Variables ─────────────────────────────────

# Adobe Firefly Services (preferred — production)
# Get from: https://developer.adobe.com/console/
# FIREFLY_CLIENT_ID=your-client-id
# FIREFLY_CLIENT_SECRET=your-client-secret
# FIREFLY_IMS_ORG_ID=your-org-id  (optional, enterprise only)

# OpenAI DALL-E 3 (development fallback)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# Provider auto-resolution: Firefly → DALL-E → Mock
# Use --mock flag to force mock mode (no API keys needed)
